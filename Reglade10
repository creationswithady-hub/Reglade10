<script>
// ─── NAV ────────────────────────────────────
const TOTAL=14;
let cur=0;
function go(d){
  const n=cur+d;
  if(n<0||n>=TOTAL)return;
  const pp=document.querySelectorAll('.page');
  pp[cur].classList.remove('active');
  pp[cur].classList.add('gone');
  pp[n].classList.remove('gone');
  pp[n].classList.add('active');
  cur=n;
  buildAllDots();
  setTimeout(()=>pp.forEach((p,i)=>{ if(i!==cur)p.classList.remove('gone'); }),520);
}
function restart(){
  const pp=document.querySelectorAll('.page');
  pp[cur].classList.remove('active');
  pp.forEach(p=>p.classList.remove('active','gone'));
  pp[0].classList.add('active');
  cur=0; buildAllDots();
}
function buildAllDots(){
  for(let i=0;i<TOTAL;i++){
    const el=document.getElementById(`d${i}`);
    if(!el)continue;
    el.innerHTML='';
    const start=Math.max(0,Math.min(cur-3,TOTAL-7));
    const end=Math.min(TOTAL-1,start+6);
    for(let j=start;j<=end;j++){
      const d=document.createElement('div');
      d.className='dot'+(j===cur?' on':'');
      el.appendChild(d);
    }
  }
}
buildAllDots();

// swipe
let tx=0;
document.getElementById('book').addEventListener('touchstart',e=>{tx=e.touches[0].clientX;},{passive:true});
document.getElementById('book').addEventListener('touchend',e=>{
  const dx=e.changedTouches[0].clientX-tx;
  if(Math.abs(dx)>48) go(dx<0?1:-1);
},{passive:true});
document.addEventListener('keydown',e=>{
  if(e.key==='ArrowRight')go(1);
  if(e.key==='ArrowLeft')go(-1);
});

// ─── TIMER ────────────────────────────────────
let tSec=600,tRun=false,tInt=null;
function toggleTimer(){
  if(tRun){ clearInterval(tInt);tRun=false;document.getElementById('tbtn').textContent='▶ Continuar'; return; }
  if(tSec<=0)tSec=600;
  tRun=true; document.getElementById('tbtn').textContent='⏸ Pausar';
  tInt=setInterval(()=>{
    tSec--;
    const m=Math.floor(tSec/60),s=tSec%60;
    document.getElementById('tnum').textContent=`${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    if(tSec<=0){
      clearInterval(tInt);tRun=false;
      document.getElementById('tnum').textContent='¡Listo!';
      document.getElementById('tlbl').textContent='☕ ¡Ese descanso te lo merecías!';
      document.getElementById('tbtn').textContent='🔄 Reiniciar';
      tSec=600; boom();
    }
  },1000);
}

// ─── COLORING ─────────────────────────────────
const PALS={
  4:['#FFB6C1','#FF85A1','#FFD700','#B0D8FF','#B5EAB5','#EAB5FF','#FF9966','#FFFDF9','#F2D2A9','#FFE4F0'],
  5:['#C4824A','#E8A87C','#F9D29D','#FFD700','#B0D8FF','#FF7755','#FFFDF9','#7B3F00','#FFDEAD','#A8D8A8'],
  6:['#E8890C','#F5C842','#D2691E','#8B5E3C','#A8D5A2','#FFFDF9','#C0C0C0','#B0D8FF','#FF8C00','#FFF3DC'],
  7:['#E8340A','#FF7733','#F5C842','#FFF8DC','#FFFDF9','#D2691E','#7B3F00','#B0D8FF','#A8D5A2','#FFDEAD'],
  8:['#8B5E3C','#C4824A','#D2B48C','#F9D29D','#FFD700','#FF7755','#FFFDF9','#FFDEAD','#228B22','#B0D8FF'],
  9:['#FFB6C1','#FF69B4','#EAB5FF','#DDA0FF','#FFFDF9','#FFD700','#B0D8FF','#D2691E','#F9D29D','#A8D5A2']
};
const curCol={}, isEr={};

function buildAll(){
  for(let pg=4;pg<=9;pg++){
    curCol[pg]=PALS[pg][0]; isEr[pg]=false;
    const pal=document.getElementById(`pal${pg}`);
    PALS[pg].forEach((c,i)=>{
      const sw=document.createElement('div');
      sw.className='swatch'+(i===0?' on':'');
      sw.style.background=c;
      const isLight=['#FFFDF9','#FFF8DC','#FFFBEF','#FFF3DC'].includes(c);
      if(isLight) sw.style.boxShadow='0 0 0 1.5px #ddd,0 2px 6px rgba(0,0,0,.1)';
      sw.onclick=()=>{
        pal.querySelectorAll('.swatch').forEach(s=>s.classList.remove('on'));
        sw.classList.add('on');
        curCol[pg]=c; isEr[pg]=false;
      };
      pal.appendChild(sw);
    });
    wireSvg(pg);
  }
}

function wireSvg(pg){
  document.querySelectorAll(`#svg${pg} .c`).forEach(el=>{
    el.style.cursor='pointer';
    const paint=()=>{ el.style.fill=isEr[pg]?'white':curCol[pg]; };
    el.addEventListener('click',paint);
    el.addEventListener('touchend',e=>{ e.preventDefault(); paint(); },{passive:false});
  });
}

function setEr(pg){
  isEr[pg]=true;
  document.getElementById(`pal${pg}`).querySelectorAll('.swatch').forEach(s=>s.classList.remove('on'));
}

function clr(pg){
  document.querySelectorAll(`#svg${pg} .c`).forEach(el=>el.style.fill='white');
  isEr[pg]=false;
  const pal=document.getElementById(`pal${pg}`);
  pal.querySelectorAll('.swatch').forEach(s=>s.classList.remove('on'));
  pal.querySelector('.swatch').classList.add('on');
  curCol[pg]=PALS[pg][0];
}

buildAll();

// ─── CONFETTI ─────────────────────────────────
function boom(){
  const box=document.getElementById('cb');
  const cols=['#F5C842','#E8890C','#A8D5A2','#FFB6C1','#B0D8FF','#EAB5FF','#FF9966','#C4824A'];
  for(let i=0;i<65;i++){
    setTimeout(()=>{
      const p=document.createElement('div');
      p.className='cf';
      p.style.cssText=`left:${Math.random()*100}%;top:-10px;background:${cols[~~(Math.random()*cols.length)]};width:${7+Math.random()*8}px;height:${7+Math.random()*8}px;border-radius:${Math.random()>.5?'50%':'2px'};animation-duration:${1.3+Math.random()*1.5}s;`;
      box.appendChild(p);
      setTimeout(()=>p.remove(),3000);
    },i*28);
  }
}
</script>
